{
  "name": "@callydus/onramp-react",
  "version": "0.1.0",
  "description": "React hooks and context for solana-onramp — integrates the OnrampClient with React state management",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.0.0",
    "react": "^18.0.0"
  },
  "dependencies": {
    "@callydus/onramp-core": "workspace:*"
  },
  "devDependencies": {
    "@solana/web3.js": "^1.98.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^18.0.0",
    "@types/node": "^20.0.0",
    "jsdom": "^24.0.0",
    "react": "^18.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
